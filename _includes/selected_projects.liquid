{% comment %}  
Selected Projects Component  
Usage:  
{% include selected_projects.liquid count=3 category="work" %}  
{% include selected_projects.liquid featured=true %}  
{% endcomment %}  
  
{%- assign project_count = include.count | default: 3 -%}  
{%- assign filter_category = include.category -%}  
{%- assign featured_only = include.featured -%}  
  
{%- comment %}Filter projects based on parameters{% endcomment -%}  
{%- if filter_category -%}  
  {%- assign filtered_projects = site.projects | where: "category", filter_category -%}  
{%- else -%}  
  {%- assign filtered_projects = site.projects -%}  
{%- endif -%}  
  
{%- if featured_only -%}  
  {%- assign filtered_projects = filtered_projects | where: "featured", true -%}  
{%- endif -%}  
  
{%- comment %}Sort by importance and limit count{% endcomment -%}  
{%- assign selected_projects = filtered_projects | sort: 'importance' | slice: 0, project_count -%}  
  
{%- if selected_projects.size > 0 -%}  
<div class="selected-projects">  
  {% if include.title %}  
    <h2 class="mb-4">{{ include.title }}</h2>  
  {% endif %}  
    
  <div class="row row-cols-1 row-cols-md-{{ include.cols | default: 3 }}">  
    {% for project in selected_projects %}  
      <div class="col mb-4">  
        <div class="card h-100 project-card">  
          {% if project.img %}  
            <a href="{{ project.url | relative_url }}">  
              {% include figure.liquid   
                loading="eager"   
                path=project.img   
                title=project.title   
                class="card-img-top"   
              %}  
            </a>  
          {% endif %}  
            
          <div class="card-body d-flex flex-column">  
            <h5 class="card-title"> {{ project.title }} </h5>  
              
            {% if project.description %}  
              <p class="card-text text-muted">{{ project.description }}</p>  
            {% endif %}  
 
          </div>  
        </div>  
      </div>  
    {% endfor %}  
  </div>  
</div>  

{%- endif -%}